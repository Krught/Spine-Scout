{% extends 'base.html.twig' %}

{% block title %}Development - Spine Scout{% endblock %}

{% block body %}
    <div class="settings">
        <header class="settings-header">
            <h1>Development</h1>
            <p>Manual test harnesses for in-progress features. Not available in production.</p>
        </header>

        <nav class="settings-tabs" aria-label="Development tools">
            {% set tabs = [
                { id: 'direct_download', label: 'Direct Download Probe', route: 'dev_direct_download' },
                { id: 'hardcover', label: 'Hardcover Inspector', route: 'dev_hardcover' },
                { id: 'komga', label: 'Komga Inspector', route: 'dev_komga' },
                { id: 'indexers', label: 'Indexer Search', route: 'dev_indexers' },
                { id: 'downloads', label: 'Downloads Activity', route: 'dev_downloads' }
            ] %}
            {% for tab in tabs %}
                <a class="settings-tab{% if active_tab == tab.id %} active{% endif %}" href="{{ path(tab.route) }}">{{ tab.label }}</a>
            {% endfor %}
        </nav>

        {% for label, messages in app.flashes %}
            {% for msg in messages %}
                <div class="flash flash-{{ label }}">{{ msg }}</div>
            {% endfor %}
        {% endfor %}

        <div class="settings-panel">
            {% block dev_body %}{% endblock %}
        </div>
    </div>
{% endblock %}
