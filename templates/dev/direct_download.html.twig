{% extends 'dev/_layout.html.twig' %}

{% block dev_body %}
    <div class="panel-header">
        <h2 class="panel-title">Direct-download search probe</h2>
    </div>

    <section class="dev-test">
        <form method="get" action="{{ path('dev_direct_download') }}" class="settings-form dev-form">
            <input type="hidden" name="sources_submitted" value="1">

            <div class="dev-config">
                <h4>Sources for this run</h4>
                {% if source_rows is empty %}
                    <p class="form-note">Nothing saved yet — configure mirrors in Settings → Direct Downloads.</p>
                {% else %}
                    <ul class="dev-config__list">
                        {% for row in source_rows %}
                            <li>
                                <label class="field field--inline">
                                    <input type="checkbox" name="enabled[]" value="{{ row.id }}"{{ row.enabled ? ' checked' : '' }}{{ row.count == 0 ? ' disabled' : '' }}>
                                    <strong>{{ row.label }}</strong>
                                    — {{ row.count }} mirror(s){% if row.first %}, first: <code>{{ row.first }}</code>{% endif %}
                                    {% if not row.saved_enabled %}<em>(disabled in saved settings)</em>{% endif %}
                                    {% if row.count == 0 %}<em>(no mirrors — add some in Settings)</em>{% endif %}
                                </label>
                            </li>
                        {% endfor %}
                    </ul>
                    <p class="form-note">Checked = run this source now. Unchecking only affects this probe run; saved settings are untouched.</p>
                {% endif %}
            </div>

            <div class="dev-form__grid">
                <label class="field">
                    <span>ISBN</span>
                    <input type="text" name="isbn" value="{{ inputs.isbn }}" placeholder="9780345539786" autocomplete="off">
                </label>
                <label class="field">
                    <span>Author</span>
                    <input type="text" name="author" value="{{ inputs.author }}" placeholder="Pierce Brown" autocomplete="off">
                </label>
                <label class="field">
                    <span>Book title</span>
                    <input type="text" name="title" value="{{ inputs.title }}" placeholder="Red Rising" autocomplete="off">
                </label>
                <label class="field">
                    <span>Publisher <em>(optional)</em></span>
                    <input type="text" name="publisher" value="{{ inputs.publisher }}" placeholder="Del Rey" autocomplete="off">
                </label>
                <label class="field">
                    <span>Published year <em>(optional)</em></span>
                    <input type="text" name="year" value="{{ inputs.year }}" placeholder="2014" autocomplete="off">
                </label>
                <label class="field">
                    <span>Language <em>(optional)</em></span>
                    <input type="text" name="language" value="{{ inputs.language }}" placeholder="en" autocomplete="off">
                </label>
            </div>
            <p class="form-note">ISBN-first: when an ISBN is given it drives the query; otherwise title + author are used. Publisher / year / language only affect scoring (extra categories), not the search.</p>
            <div class="form-actions">
                <button type="submit" name="submit" value="1" class="btn btn-primary">Generate URLs</button>
                <button type="submit" name="fetch" value="1" class="btn">Generate &amp; fetch</button>
            </div>
            <p class="form-note">After fetching, use <strong>Detail + score</strong> on a row to verify ISBNs and score that single record (one request at a time).</p>
        </form>

        {% if searches is not empty %}
            <div class="dev-result">
                <h4>Generated queries</h4>
                {% for s in searches %}
                    <div class="dev-result__source">
                        <h5>{{ s.label }}</h5>
                        {% if s.available and s.url %}
                            <p class="form-note">Mirror: <code>{{ s.mirror }}</code></p>
                            <pre class="dev-result__url">{{ s.url }}</pre>
                            <p><a href="{{ s.url }}" target="_blank" rel="noopener noreferrer">Open in new tab ↗</a></p>
                        {% else %}
                            <p class="flash flash-error">{{ s.reason ?? 'No usable mirror.' }}</p>
                        {% endif %}
                    </div>
                {% endfor %}
            </div>
        {% endif %}

        {% if runs is not null %}
            <div class="dev-result">
                <h4>Live results</h4>
                {% if runs is empty %}
                    <p class="form-note">No enabled source ran — enable a source above and add mirrors in Settings.</p>
                {% endif %}
                {% for run in runs %}
                    {% set s = run.search %}
                    <div class="dev-result__source">
                        <h5>{{ s.label }}</h5>
                        {% if not s.available %}
                            <p class="flash flash-error">{{ s.reason ?? 'Source unavailable.' }}</p>
                        {% else %}
                            <p class="form-note">Mirror: <code>{{ s.mirror }}</code>{% if s.url %} · <a href="{{ s.url }}" target="_blank" rel="noopener noreferrer">query ↗</a>{% endif %}</p>
                            <p class="form-note">
                                Parsed <strong>{{ run.records|length }}</strong> record(s)
                                {% if run.records is empty %} — no match, or a challenge/landing page was returned{% endif %}
                            </p>
                            {% if run.records is not empty %}
                                <div class="dev-result__table-wrap">
                                    <table class="dev-result__table">
                                        <thead>
                                            <tr><th>Id</th><th>Title</th><th>Author</th><th>Format</th><th>Size</th><th>Detail + score</th></tr>
                                        </thead>
                                        <tbody>
                                            {% for r in run.records %}
                                                <tr>
                                                    <td><code>{{ r.id|slice(0, 12) }}</code></td>
                                                    <td>{{ r.title }}</td>
                                                    <td>{{ r.author ?? '?' }}</td>
                                                    <td>{{ r.format ?? '?' }}</td>
                                                    <td>{{ r.size ?? '?' }}</td>
                                                    <td>
                                                        {% if r.mirror %}
                                                            <a href="{{ path('dev_direct_download', {
                                                                submit: 1,
                                                                isbn: inputs.isbn,
                                                                author: inputs.author,
                                                                title: inputs.title,
                                                                publisher: inputs.publisher,
                                                                year: inputs.year,
                                                                language: inputs.language,
                                                                detail: r.id,
                                                                mirror: r.mirror,
                                                                source: s.sourceId,
                                                                info: r.infoUrl,
                                                                rtitle: r.title,
                                                                rauthor: r.author,
                                                                rformat: r.format,
                                                                rpublisher: r.publisher,
                                                                ryear: r.year,
                                                                rlanguage: r.language,
                                                            }) }}#record-detail">Detail + score</a>
                                                        {% else %}—{% endif %}
                                                    </td>
                                                </tr>
                                            {% endfor %}
                                        </tbody>
                                    </table>
                                </div>
                            {% endif %}
                        {% endif %}
                    </div>
                {% endfor %}
            </div>
        {% endif %}

        {% if detail is not null %}
            <div class="dev-result" id="record-detail">
                <h4>Record detail — {{ detail.source }} · <code>{{ detail.hash|slice(0, 16) }}</code></h4>
                <p class="form-note">Mirror: <code>{{ detail.mirror }}</code></p>
                {% if detail.error %}
                    <p class="flash flash-error">Detail fetch failed: {{ detail.error }}</p>
                {% else %}
                    <p>
                        <strong>Verified ISBNs:</strong>
                        {% if detail.isbns is empty %}<em>none parsed</em>
                        {% else %}{% for i in detail.isbns %}<code>{{ i }}</code>{% if not loop.last %}, {% endif %}{% endfor %}{% endif %}
                    </p>
                    {% if detail.raw is not empty %}
                        <table class="dev-result__table">
                            <thead><tr><th>Label</th><th>Value(s)</th></tr></thead>
                            <tbody>
                                {% for label, values in detail.raw %}
                                    <tr><td>{{ label }}</td><td>{{ values|join(' · ') }}</td></tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    {% endif %}
                    <p class="form-note">Download links found: <strong>{{ detail.links|length }}</strong></p>
                    {% if detail.links is not empty %}
                        <ul class="dev-config__list">
                            {% for link in detail.links %}<li><code>{{ link }}</code></li>{% endfor %}
                        </ul>

                        <div class="dev-dl-test"
                             data-controller="download-test"
                             data-download-test-url-value="{{ path('dev_direct_download_test') }}"
                             data-download-test-token-value="{{ csrf_token('dev_dd_download_test') }}"
                             data-download-test-links-value="{{ detail.links|json_encode }}">
                            <div class="form-actions">
                                <button type="button" class="btn btn-primary"
                                        data-download-test-target="button"
                                        data-action="download-test#run">
                                    Test download all links
                                </button>
                            </div>
                            <p class="form-note">
                                Runs the <strong>real</strong> download workflow against <strong>every</strong>
                                link above (same code path as fulfillment: hand the link to the bypasser,
                                resolve the returned partner link, then download from there). Each step is
                                shown per link. Files are written to a temp directory, measured, then
                                deleted — nothing is kept.
                            </p>
                            <div class="dev-dl-test__results" data-download-test-target="results" hidden></div>
                        </div>
                    {% endif %}

                    {% if detail.score is defined %}
                        {% set sc = detail.score %}
                        {% set qualifies = sc.total >= detail.threshold %}
                        <h4>Score — <strong>{{ sc.total }}</strong>/100
                            ({{ qualifies ? '✓ qualifies' : '✗ below threshold' }} {{ detail.threshold }})</h4>
                        <p class="form-note">
                            Earned <strong>{{ sc.earned }}</strong> of <strong>{{ sc.maxPossible }}</strong> achievable points
                            (only categories present in the request count). Threshold is a percentage, so it scales with how many categories were sent.
                        </p>
                        <table class="dev-result__table">
                            <thead><tr><th>Category</th><th>Earned</th><th>Match</th><th>Note</th><th>Request</th><th>Candidate</th></tr></thead>
                            <tbody>
                                {% for c in sc.categories %}
                                    <tr{% if not c.sent %} style="opacity:.5"{% endif %}>
                                        <td>{{ c.label }}</td>
                                        <td>{% if c.sent %}{{ c.earned }} / {{ c.weight }}{% else %}— / {{ c.weight }}{% endif %}</td>
                                        <td>{% if c.sent %}{{ (c.fraction * 100)|round }}%{% else %}—{% endif %}</td>
                                        <td>{{ c.note }}</td>
                                        <td>{{ c.planValue ?: '—' }}</td>
                                        <td>{{ c.candidateValue ?: '—' }}</td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                        <p class="form-note">Greyed rows weren't part of the request, so they didn't count toward the achievable total.</p>
                    {% endif %}
                {% endif %}
            </div>
        {% endif %}
    </section>
{% endblock %}
