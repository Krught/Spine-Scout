<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Spine Scout{% endblock %}</title>
        <link rel="icon" type="image/x-icon" href="{{ asset('favicon.ico') }}">
        <link rel="icon" type="image/png" sizes="16x16" href="{{ asset('favicon-16.png') }}">
        <link rel="icon" type="image/png" sizes="32x32" href="{{ asset('favicon-32.png') }}">
        <link rel="icon" type="image/png" sizes="192x192" href="{{ asset('icon-192.png') }}">
        <link rel="icon" type="image/png" sizes="512x512" href="{{ asset('icon-512.png') }}">
        <link rel="apple-touch-icon" sizes="180x180" href="{{ asset('apple-touch-icon.png') }}">
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body>
        <div class="app-shell" data-controller="sidebar">
            <div class="sidebar-backdrop" data-action="click->sidebar#close" aria-hidden="true"></div>
            <aside class="sidebar">
                <a class="brand brand-spine" href="{{ path('home') }}" aria-label="Spine Scout home">
                    <img src="{{ asset('images/spine-scout-logo.webp') }}" alt="Spine Scout" class="brand-spine-img">
                </a>

                {% set current_route = app.request.attributes.get('_route') ?? '' %}
                <nav class="sidebar-nav" data-action="click->sidebar#close">
                    <a class="nav-item{% if current_route == 'home' %} active{% endif %}" href="{{ path('home') }}">
                        <svg class="nav-icon" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <circle cx="12" cy="12" r="9"/>
                            <polygon points="15.5,8.5 10,10 8.5,15.5 14,14"/>
                        </svg>
                        <span class="nav-text">Discover</span>
                    </a>
                    <a class="nav-item{% if current_route == 'browse' %} active{% endif %}" href="{{ path('browse') }}">
                        <svg class="nav-icon" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M4 5a2 2 0 0 1 2-2h12v17H6a2 2 0 0 1-2-2z"/>
                            <line x1="8" y1="7" x2="14" y2="7"/>
                            <line x1="8" y1="11" x2="14" y2="11"/>
                        </svg>
                        <span class="nav-text">Browse</span>
                    </a>
                    <a class="nav-item" href="#">
                        <svg class="nav-icon" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M21 11.5a8.4 8.4 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.4 8.4 0 0 1-3.8-.9L3 21l1.9-5.7a8.4 8.4 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.4 8.4 0 0 1 3.8-.9h.5a8.5 8.5 0 0 1 8 8z"/>
                        </svg>
                        <span class="nav-text">Requests</span>
                    </a>
                    <a class="nav-item" href="#">
                        <svg class="nav-icon" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
                            <circle cx="9" cy="7" r="4"/>
                            <path d="M22 21v-2a4 4 0 0 0-3-3.87"/>
                            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                        </svg>
                        <span class="nav-text">Users</span>
                    </a>
                    <a class="nav-item{% if current_route starts with 'settings_' %} active{% endif %}" href="{{ path('settings_index') }}">
                        <svg class="nav-icon" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <circle cx="12" cy="12" r="3"/>
                            <path d="M19.4 15a1.7 1.7 0 0 0 .3 1.8l.1.1a2 2 0 1 1-2.8 2.8l-.1-.1a1.7 1.7 0 0 0-1.8-.3 1.7 1.7 0 0 0-1 1.5V21a2 2 0 1 1-4 0v-.1a1.7 1.7 0 0 0-1-1.5 1.7 1.7 0 0 0-1.8.3l-.1.1a2 2 0 1 1-2.8-2.8l.1-.1a1.7 1.7 0 0 0 .3-1.8 1.7 1.7 0 0 0-1.5-1H3a2 2 0 1 1 0-4h.1a1.7 1.7 0 0 0 1.5-1 1.7 1.7 0 0 0-.3-1.8l-.1-.1a2 2 0 1 1 2.8-2.8l.1.1a1.7 1.7 0 0 0 1.8.3h0a1.7 1.7 0 0 0 1-1.5V3a2 2 0 1 1 4 0v.1a1.7 1.7 0 0 0 1 1.5h0a1.7 1.7 0 0 0 1.8-.3l.1-.1a2 2 0 1 1 2.8 2.8l-.1.1a1.7 1.7 0 0 0-.3 1.8v0a1.7 1.7 0 0 0 1.5 1H21a2 2 0 1 1 0 4h-.1a1.7 1.7 0 0 0-1.5 1z"/>
                        </svg>
                        <span class="nav-text">Settings</span>
                    </a>
                </nav>

                <div class="sidebar-footer">
                    {% set version_up_to_date = app_version == app_latest_version %}
                    <div class="version-badge{% if version_up_to_date %} version-badge-ok{% else %} version-badge-stale{% endif %}"
                         title="Installed {{ app_version }} · latest {{ app_latest_version }}">
                        {% if version_up_to_date %}
                            <span class="version-check" aria-hidden="true">
                                <svg viewBox="0 0 24 24" width="12" height="12" focusable="false">
                                    <path d="M5 12.5l4.2 4.2L19 7" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                            </span>
                            <span class="version-label">Up to date</span>
                        {% else %}
                            <span class="version-label">Update available</span>
                        {% endif %}
                        <span class="version-number">v{{ app_version }}</span>
                    </div>
                </div>
            </aside>

            <div class="content">
                <header class="topbar">
                    <button type="button" class="topbar-menu-btn" data-action="click->sidebar#toggle" aria-label="Open menu">
                        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <line x1="4" y1="6" x2="20" y2="6"/>
                            <line x1="4" y1="12" x2="20" y2="12"/>
                            <line x1="4" y1="18" x2="20" y2="18"/>
                        </svg>
                    </button>
                    <a class="topbar-brand" href="{{ path('home') }}">Spine Scout</a>
                    {% set _q_type = app.request.query.get('type') %}
                    {% set _q_type = _q_type in ['title', 'author', 'genre', 'series', 'publisher'] ? _q_type : 'title' %}
                    <div class="search-wrap"
                         data-controller="search"
                         data-search-browse-url-value="{{ path('browse') }}"
                         data-search-current-route-value="{{ current_route }}"
                         data-search-type-value="{{ _q_type }}">
                        <button type="button" class="search-icon-btn" data-action="click->search#toggleMobile" aria-label="Search">
                            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                                <circle cx="11" cy="11" r="7"/>
                                <line x1="21" y1="21" x2="16.65" y2="16.65"/>
                            </svg>
                        </button>
                        <input type="search" placeholder="Search for books, authors, series..."
                               class="search-input"
                               data-search-target="input"
                               data-action="input->search#onInput keydown.enter->search#submit keydown.escape->search#onInputKeydown">
                        <div class="search-types" role="group" aria-label="Search type">
                            <button type="button"
                                    class="search-type-btn{% if _q_type == 'title' %} is-active{% endif %}"
                                    data-search-target="typeButton"
                                    data-search-type-param="title"
                                    data-action="click->search#setType"
                                    aria-pressed="{{ _q_type == 'title' ? 'true' : 'false' }}"
                                    title="Search book titles" aria-label="Search book titles">
                                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" focusable="false" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h12a3 3 0 0 1 3 3v13H7a3 3 0 0 1-3-3z"/><path d="M4 17a3 3 0 0 1 3-3h12"/></svg>
                            </button>
                            <button type="button"
                                    class="search-type-btn{% if _q_type == 'author' %} is-active{% endif %}"
                                    data-search-target="typeButton"
                                    data-search-type-param="author"
                                    data-action="click->search#setType"
                                    aria-pressed="{{ _q_type == 'author' ? 'true' : 'false' }}"
                                    title="Search by author" aria-label="Search by author">
                                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" focusable="false" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="4"/><path d="M4 21a8 8 0 0 1 16 0"/></svg>
                            </button>
                            <button type="button"
                                    class="search-type-btn{% if _q_type == 'genre' %} is-active{% endif %}"
                                    data-search-target="typeButton"
                                    data-search-type-param="genre"
                                    data-action="click->search#setType"
                                    aria-pressed="{{ _q_type == 'genre' ? 'true' : 'false' }}"
                                    title="Search by genre" aria-label="Search by genre">
                                <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" focusable="false" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.6 13.4 13.4 20.6a2 2 0 0 1-2.8 0L3 13V3h10l7.6 7.6a2 2 0 0 1 0 2.8z"/><circle cx="7.5" cy="7.5" r="1.5"/></svg>
                            </button>
                        </div>
                    </div>
                    <div class="topbar-right">
                        {% if app.user %}
                            <a class="avatar" href="{{ path('app_logout') }}" title="Sign out ({{ app.user.username }})">{{ app.user.username|slice(0, 1)|upper }}</a>
                            <a class="topbar-logout" href="{{ path('app_logout') }}">Sign out</a>
                        {% endif %}
                    </div>
                </header>

                <main class="main">
                    {% block body %}{% endblock %}
                </main>
            </div>
        </div>
    </body>
</html>
