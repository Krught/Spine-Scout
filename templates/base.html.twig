<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Spine Scout{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><rect width=%22128%22 height=%22128%22 rx=%2224%22 fill=%22%23f0b429%22/><text x=%2250%25%22 y=%2274%22 font-size=%2280%22 font-family=%22system-ui,sans-serif%22 font-weight=%22700%22 text-anchor=%22middle%22 fill=%22%231a1a1a%22>S</text></svg>">
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}
    </head>
    <body>
        <div class="app-shell">
            <aside class="sidebar">
                <a class="brand brand-spine" href="{{ path('home') }}" aria-label="Spine Scout home">
                    <img src="{{ asset('images/spine-scout-logo.webp') }}" alt="Spine Scout" class="brand-spine-img">
                </a>

                {% set current_route = app.request.attributes.get('_route') ?? '' %}
                <nav class="sidebar-nav">
                    <a class="nav-item{% if current_route == 'home' %} active{% endif %}" href="{{ path('home') }}">
                        <svg class="nav-icon" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <circle cx="12" cy="12" r="9"/>
                            <polygon points="15.5,8.5 10,10 8.5,15.5 14,14"/>
                        </svg>
                        <span class="nav-text">Discover</span>
                    </a>
                    <a class="nav-item" href="#">
                        <svg class="nav-icon" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M4 5a2 2 0 0 1 2-2h12v17H6a2 2 0 0 1-2-2z"/>
                            <line x1="8" y1="7" x2="14" y2="7"/>
                            <line x1="8" y1="11" x2="14" y2="11"/>
                        </svg>
                        <span class="nav-text">Browse</span>
                    </a>
                    <a class="nav-item" href="#">
                        <svg class="nav-icon" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M21 11.5a8.4 8.4 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.4 8.4 0 0 1-3.8-.9L3 21l1.9-5.7a8.4 8.4 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.4 8.4 0 0 1 3.8-.9h.5a8.5 8.5 0 0 1 8 8z"/>
                        </svg>
                        <span class="nav-text">Requests</span>
                    </a>
                    <a class="nav-item" href="#">
                        <svg class="nav-icon" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
                            <circle cx="9" cy="7" r="4"/>
                            <path d="M22 21v-2a4 4 0 0 0-3-3.87"/>
                            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                        </svg>
                        <span class="nav-text">Users</span>
                    </a>
                    <a class="nav-item{% if current_route starts with 'settings_' %} active{% endif %}" href="{{ path('settings_index') }}">
                        <svg class="nav-icon" viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <circle cx="12" cy="12" r="3"/>
                            <path d="M19.4 15a1.7 1.7 0 0 0 .3 1.8l.1.1a2 2 0 1 1-2.8 2.8l-.1-.1a1.7 1.7 0 0 0-1.8-.3 1.7 1.7 0 0 0-1 1.5V21a2 2 0 1 1-4 0v-.1a1.7 1.7 0 0 0-1-1.5 1.7 1.7 0 0 0-1.8.3l-.1.1a2 2 0 1 1-2.8-2.8l.1-.1a1.7 1.7 0 0 0 .3-1.8 1.7 1.7 0 0 0-1.5-1H3a2 2 0 1 1 0-4h.1a1.7 1.7 0 0 0 1.5-1 1.7 1.7 0 0 0-.3-1.8l-.1-.1a2 2 0 1 1 2.8-2.8l.1.1a1.7 1.7 0 0 0 1.8.3h0a1.7 1.7 0 0 0 1-1.5V3a2 2 0 1 1 4 0v.1a1.7 1.7 0 0 0 1 1.5h0a1.7 1.7 0 0 0 1.8-.3l.1-.1a2 2 0 1 1 2.8 2.8l-.1.1a1.7 1.7 0 0 0-.3 1.8v0a1.7 1.7 0 0 0 1.5 1H21a2 2 0 1 1 0 4h-.1a1.7 1.7 0 0 0-1.5 1z"/>
                        </svg>
                        <span class="nav-text">Settings</span>
                    </a>
                </nav>

                <div class="sidebar-footer">
                    {% set version_up_to_date = app_version == app_latest_version %}
                    <div class="version-badge{% if version_up_to_date %} version-badge-ok{% else %} version-badge-stale{% endif %}"
                         title="Installed {{ app_version }} · latest {{ app_latest_version }}">
                        {% if version_up_to_date %}
                            <span class="version-check" aria-hidden="true">
                                <svg viewBox="0 0 24 24" width="12" height="12" focusable="false">
                                    <path d="M5 12.5l4.2 4.2L19 7" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                            </span>
                            <span class="version-label">Up to date</span>
                        {% else %}
                            <span class="version-label">Update available</span>
                        {% endif %}
                        <span class="version-number">v{{ app_version }}</span>
                    </div>
                </div>
            </aside>

            <div class="content">
                <header class="topbar">
                    <div class="search-wrap">
                        <input type="search" placeholder="Search for books, authors, series..." class="search-input">
                    </div>
                    <div class="topbar-right">
                        {% if app.user %}
                            <div class="avatar" title="{{ app.user.username }}">{{ app.user.username|slice(0, 1)|upper }}</div>
                            <a class="topbar-logout" href="{{ path('app_logout') }}">Sign out</a>
                        {% endif %}
                    </div>
                </header>

                <main class="main">
                    {% block body %}{% endblock %}
                </main>
            </div>
        </div>
    </body>
</html>
