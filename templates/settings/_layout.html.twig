{% extends 'base.html.twig' %}

{% block title %}Settings - Spine Scout{% endblock %}

{% block body %}
    <div class="settings">
        <header class="settings-header">
            <h1>Settings</h1>
            <p>Configure Spine Scout, connect integrations, and manage users.</p>
        </header>

        <nav class="settings-tabs" aria-label="Settings sections">
            {% set tabs = [
                { id: 'general',   label: 'General',   route: 'settings_general' },
                { id: 'users',     label: 'Users',     route: 'settings_users' },
                { id: 'grimmory',  label: 'Grimmory',  route: 'settings_grimmory' },
                { id: 'metadata',  label: 'Metadata',  route: 'settings_metadata' }
            ] %}
            {% for tab in tabs %}
                <a class="settings-tab{% if active_tab == tab.id %} active{% endif %}" href="{{ path(tab.route) }}">{{ tab.label }}</a>
            {% endfor %}
        </nav>

        {% for label, messages in app.flashes %}
            {% for msg in messages %}
                <div class="flash flash-{{ label }}">{{ msg }}</div>
            {% endfor %}
        {% endfor %}

        <div class="settings-panel">
            {% block settings_body %}{% endblock %}
        </div>
    </div>
{% endblock %}
