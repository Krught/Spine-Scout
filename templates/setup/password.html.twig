{% extends 'setup/_layout.html.twig' %}

{% block title %}Set a password - Spine Scout{% endblock %}

{% block setup_step %}
    <h1 class="setup-title">Set your password</h1>
    <p class="setup-lede">
        Creating administrator account for
        <strong class="setup-username">{{ username }}</strong>.
        <a href="{{ path('app_setup') }}" class="setup-back-link">Change username</a>
    </p>

    <form method="post" action="{{ path('app_setup_password') }}" class="setup-form" novalidate>
        {# Help password managers attach this credential to a username. #}
        <input type="text" name="username_hint" value="{{ username }}" autocomplete="username" hidden readonly>

        <label class="setup-field">
            <span class="setup-label">Password</span>
            <input
                type="password"
                name="password"
                required
                autofocus
                minlength="8"
                autocomplete="new-password"
            >
            <span class="setup-help">At least 8 characters.</span>
        </label>

        <label class="setup-field">
            <span class="setup-label">Confirm password</span>
            <input
                type="password"
                name="password_confirm"
                required
                minlength="8"
                autocomplete="new-password"
            >
        </label>

        <input type="hidden" name="_csrf_token" value="{{ csrf_token(csrf_token) }}">

        <div class="setup-actions">
            <a href="{{ path('app_setup') }}" class="setup-back">Back</a>
            <button type="submit" class="setup-submit">Create account</button>
        </div>
    </form>
{% endblock %}
