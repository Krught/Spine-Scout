{% extends 'setup/_layout.html.twig' %}

{% block title %}Connect Komga - Spine Scout{% endblock %}

{% block setup_step %}
    <h1 class="setup-title">Connect your Grimmory library</h1>
    <p class="setup-lede">
        Spine Scout connects to your library through <strong>Komga</strong>.
        Enter your Komga server URL and account credentials below.
    </p>

    <form method="post" action="{{ path('app_setup_komga') }}" class="setup-form" novalidate>
        <label class="setup-field">
            <span class="setup-label">Komga server URL</span>
            <input
                type="url"
                name="base_url"
                value="{{ base_url }}"
                placeholder="https://komga.example.com"
                autofocus
                autocomplete="url"
                spellcheck="false"
            >
        </label>

        <label class="setup-field">
            <span class="setup-label">Username</span>
            <input
                type="text"
                name="username"
                value="{{ username }}"
                autocomplete="username"
                spellcheck="false"
            >
        </label>

        <label class="setup-field">
            <span class="setup-label">Password</span>
            <input
                type="password"
                name="password"
                autocomplete="current-password"
            >
        </label>

        <input type="hidden" name="_csrf_token" value="{{ csrf_token(csrf_token) }}">

        <div class="setup-actions">
            {# Primary submit listed first so Enter activates it, not Skip. CSS keeps Skip visually on the left. #}
            <button type="submit" class="setup-submit">Connect</button>
            <button type="submit" name="skip" value="1" class="setup-skip" formnovalidate>Skip</button>
        </div>
    </form>
{% endblock %}
