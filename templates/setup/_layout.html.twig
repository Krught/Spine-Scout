<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Set up Spine Scout{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><rect width=%22128%22 height=%22128%22 rx=%2224%22 fill=%22%23f0b429%22/><text x=%2250%25%22 y=%2274%22 font-size=%2280%22 font-family=%22system-ui,sans-serif%22 font-weight=%22700%22 text-anchor=%22middle%22 fill=%22%231a1a1a%22>S</text></svg>">
        {{ importmap('app') }}
    </head>
    <body class="setup-body">
        <main class="setup-stage">
            <header class="setup-brand">
                <span class="setup-brand-name">Spine Scout</span>
            </header>

            <div class="setup-card">
                <div class="setup-progress" aria-label="Setup progress">
                    {% for i in 1..total %}
                        <span class="setup-dot{% if i == step %} setup-dot-active{% elseif i < step %} setup-dot-done{% endif %}"></span>
                    {% endfor %}
                    <span class="setup-progress-text">Step {{ step }} of {{ total }}</span>
                </div>

                {% if error %}
                    <p class="setup-error" role="alert">{{ error }}</p>
                {% endif %}

                {% block setup_step %}{% endblock %}
            </div>
        </main>
    </body>
</html>
