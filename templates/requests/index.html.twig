{% extends 'base.html.twig' %}

{% block title %}Requests - Spine Scout{% endblock %}

{% block body %}
    <section class="requests-section" data-controller="request-search requests-filter book-modal">
        <header class="requests-header">
            <h1 class="requests-title">Requests</h1>
        </header>

        {% for label, messages in app.flashes %}
            {% for msg in messages %}
                <div class="flash flash-{{ label }}">{{ msg }}</div>
            {% endfor %}
        {% endfor %}

        {% if items is empty %}
            <div class="requests-empty">No requests yet.</div>
        {% else %}
            <div class="requests-filters" role="group" aria-label="Filter requests by status">
                {% for f in filters %}
                    <button type="button"
                            class="requests-filter{{ f.key == 'all' ? ' is-active' : '' }}"
                            data-requests-filter-target="chip"
                            data-status-key="{{ f.key }}"
                            data-action="requests-filter#select"
                            data-requests-filter-key-param="{{ f.key }}">
                        {{ f.label }} <span class="requests-filter-count">{{ f.count }}</span>
                    </button>
                {% endfor %}
            </div>

            {% if format_filters is not empty %}
                <div class="requests-filters requests-format-filters" role="group" aria-label="Filter requests by format">
                    {% for f in format_filters %}
                        <button type="button"
                                class="requests-filter{{ f.key == 'all' ? ' is-active' : '' }}"
                                data-requests-filter-target="formatChip"
                                data-format-key="{{ f.key }}"
                                data-action="requests-filter#selectFormat"
                                data-requests-filter-key-param="{{ f.key }}">
                            {{ f.label }} <span class="requests-filter-count">{{ f.count }}</span>
                        </button>
                    {% endfor %}
                </div>
            {% endif %}

            <div class="requests-empty requests-filter-empty" data-requests-filter-target="empty" hidden>
                No requests match these filters.
            </div>

            <ul class="requests-list">
                {% set _cover_gradients = [
                    'linear-gradient(135deg,#3a4a6b,#5c6f99)',
                    'linear-gradient(135deg,#7a3a5f,#a85b85)',
                    'linear-gradient(135deg,#2f5a4e,#508a76)',
                    'linear-gradient(135deg,#6b4a2a,#a3754a)',
                    'linear-gradient(135deg,#3d3d6b,#6a6ab0)',
                    'linear-gradient(135deg,#5a2a3d,#8a4a60)',
                ] %}
                {% for item in items %}
                    {% set r = item.entity %}
                    {% set status = r.status %}
                    {% set is_owner = app.user and app.user.id == r.requestedBy.id %}
                    {% set can_approve = is_granted('ROLE_ADMIN') and status == 'pending' %}
                    {% set can_recheck = is_granted('ROLE_ADMIN') and status == 'approved' and (r.deliveryStatus is null or r.deliveryStatus in ['error', 'cancelled'] or item.stalled) %}
                    {% set can_delete = is_granted('ROLE_ADMIN') or is_owner %}
                    {% set is_fulfilled = status == 'available' or (status == 'approved' and r.deliveryStatus == 'complete') %}
                    {% set can_search = is_granted('ROLE_ADMIN') and not is_fulfilled %}
                    {% set _dur = random(900, 3600) %}
                    <li class="request-row" data-controller="cover-palette" data-cover-palette-target-value=".request-cover"
                        data-requests-filter-target="row" data-status-key="{{ item.status_key }}"
                        data-format="{{ item.format_key }}"
                        style="--row-fill-duration: {{ _dur }}ms;">
                        <div class="request-left request-left-clickable" role="button" tabindex="0"
                             data-action="click->book-modal#open keydown.enter->book-modal#open keydown.space->book-modal#open"
                             data-book-modal-id-param="{{ r.book.id }}"
                             data-book-modal-title-param="{{ r.book.title }}"
                             data-book-modal-author-param="{{ r.book.author ?? '' }}"
                             data-book-modal-cover-param="{{ item.cover_url ?? '' }}"
                             data-book-modal-downloaded-param="{{ is_fulfilled ? '1' : '0' }}"
                             data-book-modal-request-status-param="{{ item.status_key }}"
                             data-book-modal-audiobook-param="{{ r.book.audiobookAvailable ? '1' : '0' }}"
                             data-book-modal-mode-param="{{ r.audiobook ? 'audiobook' : 'book' }}">
                            {% if item.cover_url %}
                                <img class="request-cover" src="{{ item.cover_url }}" alt="" loading="lazy">
                            {% else %}
                                <div class="request-cover request-cover-placeholder" aria-hidden="true"
                                     style="background: {{ _cover_gradients[loop.index0 % 6] }};">
                                    <span class="request-cover-title">{{ r.book.title|slice(0, 24) }}</span>
                                </div>
                            {% endif %}
                            <div class="request-titleblock">
                                <div class="request-booktitle">{{ r.book.title }}</div>
                                {% if r.book.author %}
                                    <div class="request-bookauthor">{{ r.book.author }}</div>
                                {% endif %}
                            </div>
                        </div>

                        <div class="request-meta">
                            <span class="request-format request-format-{{ item.format_key }}">{{ item.format_key == 'audiobook' ? 'Audiobook' : 'Book' }}</span>
                            <span class="request-status request-status-{{ item.status_key }}">{{ item.status_label }}</span>
                            <span class="request-when">
                                Requested {{ item.ago }} by <strong>{{ r.requestedBy.username }}</strong>
                            </span>
                            {% if item.downloaded_ago %}
                                <span class="request-when request-when-downloaded" title="{{ item.downloaded_at|date('M j, Y g:i A') }}">
                                    Downloaded {{ item.downloaded_ago }}
                                </span>
                            {% endif %}
                        </div>

                        <div class="request-actions">
                            {% if can_search %}
                                <button type="button" class="request-btn request-btn-search"
                                        data-action="request-search#open"
                                        data-request-search-book-id-param="{{ r.book.id }}"
                                        data-request-search-title-param="{{ r.book.title }}"
                                        data-request-search-author-param="{{ r.book.author ?? '' }}"
                                        data-request-search-isbn-param="{{ r.book.isbn ?? '' }}"
                                        title="Manually search sources and download a version">Interactive Search</button>
                            {% endif %}
                            {% if can_approve %}
                                <form method="post" action="{{ path('requests_approve', {id: r.id}) }}">
                                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('approve-request-' ~ r.id) }}">
                                    <button type="submit" class="request-btn request-btn-approve">Approve</button>
                                </form>
                            {% endif %}
                            {% if can_recheck %}
                                <form method="post" action="{{ path('requests_recheck', {id: r.id}) }}">
                                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('recheck-request-' ~ r.id) }}">
                                    <button type="submit" class="request-btn request-btn-recheck" title="Search and download again now">Recheck now</button>
                                </form>
                            {% endif %}
                            {% if can_delete %}
                                <form method="post" action="{{ path('requests_delete', {id: r.id}) }}"
                                      onsubmit="return confirm('Remove this request?');">
                                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('delete-request-' ~ r.id) }}">
                                    <button type="submit" class="request-btn request-btn-delete">Remove Request</button>
                                </form>
                            {% endif %}
                        </div>
                    </li>
                {% endfor %}
            </ul>
        {% endif %}

        {# Book detail popup, opened by clicking a request's cover/title. No interactive-search
           panel here (admins use the per-row button), so the modal's own Interactive Search
           button is hidden via CSS. #}
        <div class="book-modal" data-book-modal-target="modal" data-action="click->book-modal#backdropClick keydown.esc@window->book-modal#close interactive-search:downloaded@window->book-modal#onDownloaded" hidden>
            <div class="book-modal-dialog" role="dialog" aria-modal="true" aria-labelledby="book-modal-title">
                <button type="button" class="book-modal-refresh" aria-label="Refresh metadata" title="Refresh metadata" data-book-modal-target="refresh" data-action="click->book-modal#refreshMetadata">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <path d="M21 12a9 9 0 1 1-2.64-6.36"/>
                        <path d="M21 3v6h-6"/>
                    </svg>
                </button>
                <button type="button" class="book-modal-close" aria-label="Close" data-action="click->book-modal#close">×</button>
                <div class="book-modal-body">
                    <div class="book-modal-cover-wrap">
                        <div class="book-modal-cover" data-book-modal-target="cover"></div>
                        <button type="button" class="book-modal-action" data-book-modal-target="action" data-action="click->book-modal#requestBook" hidden></button>
                        <button type="button" class="book-modal-search" data-book-modal-target="search" data-action="click->book-modal#openSearch" hidden>Interactive Search</button>
                        <button type="button" class="book-modal-search book-modal-recommend" data-book-modal-target="recommend" data-action="click->book-modal#moreLikeThis" hidden>More like this</button>
                    </div>
                    <div class="book-modal-content">
                        <h2 class="book-modal-title" id="book-modal-title" data-book-modal-target="title"></h2>
                        <div class="book-modal-author" data-book-modal-target="author"></div>
                        <div class="book-modal-format" data-book-modal-target="format" hidden></div>
                        <div class="book-modal-status" data-book-modal-target="status">Loading…</div>
                        <dl class="book-modal-facts" data-book-modal-target="facts"></dl>
                        <div class="book-modal-genres" data-book-modal-target="genres"></div>
                        <div class="book-modal-description" data-book-modal-target="description"></div>
                    </div>
                </div>
            </div>
        </div>

        {% if is_granted('ROLE_ADMIN') %}
            <div class="book-modal request-search-overlay" data-request-search-target="overlay"
                 data-action="click->request-search#backdropClick" hidden>
                <div class="book-modal-dialog">
                    {{ include('_interactive_search.html.twig') }}
                </div>
            </div>
        {% endif %}
    </section>
{% endblock %}
